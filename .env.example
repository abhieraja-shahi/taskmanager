# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=tasktracker
MYSQL_USER=taskuser
MYSQL_PASSWORD=change_me_password

# App (use container names as hostnames)
DATABASE_URL=mysql+aiomysql://taskuser:change_me_password@db:3306/tasktracker
SYNC_DATABASE_URL=mysql+pymysql://taskuser:change_me_password@db:3306/tasktracker
SECRET_KEY=generate_a_long_random_string_here
REDIS_URL=redis://redis:6379/0

# CORS — add your server's domain/IP here
CORS_ORIGINS=http://YOUR_SERVER_IP,https://yourdomain.com